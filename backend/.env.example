# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Optional: omit DATABASE_URL to use local SQLite
DATABASE_URL=
USE_SQLITE=True

# Gemini report analysis
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Google sign-in
GOOGLE_CLIENT_ID=

# Optional Cloudflare R2 storage
CLOUDFLARE_STORAGE_ENABLE=False
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
CLOUDFLARE_ENDPOINT_URL=

# Email: console backend is convenient for local development
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=LabSaathi <noreply@labsaathi.local>
